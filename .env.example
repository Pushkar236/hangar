# ── Orchestrator (server/) — set on Fly.io as secrets ───────────────────────
# E2B API key (operator-side). Get one free at https://e2b.dev/dashboard
E2B_API_KEY=
# The custom template built from sandbox/e2b.Dockerfile
E2B_TEMPLATE=hangar-claude-code
# Optional
PORT=8080
SANDBOX_TIMEOUT_MS=600000

# ── Web (web/) — set on Vercel ──────────────────────────────────────────────
# Public WebSocket URL of the orchestrator (Fly app), e.g.
# wss://hangar-orchestrator.fly.dev
NEXT_PUBLIC_WS_URL=ws://localhost:8080
