# ── Orchestrator (server/) — set as host secrets (Render/Fly) ───────────────
# E2B API key (operator-side). Get one free at https://e2b.dev/dashboard
E2B_API_KEY=
# Sandbox template. "base" = default sandbox + install Claude Code at session
# start (no template build). Set to a prebuilt template name to skip the install.
E2B_TEMPLATE=base
# Optional
PORT=8080
SANDBOX_TIMEOUT_MS=600000

# ── Web (web/) — set on Vercel ──────────────────────────────────────────────
# Public WebSocket URL of the orchestrator, e.g.
# wss://hangar-orchestrator.onrender.com
NEXT_PUBLIC_WS_URL=ws://localhost:8080
